# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (MongoDB) ──────────────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/myapp

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth (generate with: openssl rand -base64 48) ──────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-long
JWT_REFRESH_SECRET=change-me-different-from-access

# ── Backblaze B2 Storage (S3-compatible) ───────────────────────────────────
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@example.com

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── i18n ────────────────────────────────────────────────────────────────────
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar,fr

# ── Observability (optional) ────────────────────────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=
